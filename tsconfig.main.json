    "outDir": "dist-electron",
    "rootDir": "src",
    "noEmit": false,
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "node",
    "types": ["node"],
    "sourceMap": true
  },
  "include": ["src/main", "src/shared"]
}
